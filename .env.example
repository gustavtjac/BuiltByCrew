# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Vercel deployment
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_team_id_or_leave_empty
CUSTOM_DOMAIN=apps.yourdomain.com

# Twitter / X
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# Pipeline behaviour
MAX_IDEA_RETRIES=3
MAX_QA_RETRIES=3

# Optional: comma-separated topic hints for ideation
TOPIC_PREFERENCES=productivity,developer-tools,finance
