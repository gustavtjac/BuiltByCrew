# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Vercel deployment
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_team_id_or_leave_empty
CUSTOM_DOMAIN=apps.yourdomain.com

# Twitter / X — posted via Make.com webhook (no direct API key needed)
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id

# Reddit
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# LinkedIn
LINKEDIN_ACCESS_TOKEN=...
# Your LinkedIn URN — person: "urn:li:person:XXXX" or org: "urn:li:organization:XXXX"
LINKEDIN_AUTHOR_URN=urn:li:person:XXXX

# Pipeline behaviour
MAX_IDEA_RETRIES=3
MAX_QA_RETRIES=3

# Optional: comma-separated topic hints for ideation
TOPIC_PREFERENCES=productivity,developer-tools,finance
